{
  "expo": {
    "name": "Mini Jira",
    "slug": "minijira-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0ea5e9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.minijira.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0ea5e9"
      },
      "package": "com.minijira.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "minijira",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
